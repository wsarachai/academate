{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Vite App (Chrome)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev -- --host 127.0.0.1 --port 5173",
      "serverReadyAction": {
        "pattern": "(http://127.0.0.1:5173)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    }
  ]
}
